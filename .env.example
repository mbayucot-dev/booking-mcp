# Copy to `.env`. Points at the SAME Postgres the booking-agent uses.
DATABASE_URL=postgresql+psycopg://booking:booking@localhost:5432/booking

# Read-only by default. Set to false to enable the write tools (create_booking,
# add_customer_preference). Writes go straight to the DB and BYPASS the
# booking-agent human-approval workflow — enable deliberately.
READ_ONLY=true

# Connection pool + query guardrails (sized for FastMCP's sync-tool threadpool).
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
DB_POOL_TIMEOUT=10
DB_STATEMENT_TIMEOUT_MS=30000

LOG_LEVEL=INFO

# ── Deployment guards ─────────────────────────────────────────────────────────

# MUST be true to run `booking-mcp-seed` / create_all(). This guard prevents
# accidental schema creation against a shared DB (booking-agent owns migrations).
# Leave false when connecting to a DB already managed by booking-agent.
STANDALONE_MODE=false

# Mask phone numbers (→ last-4 digits) and addresses (→ [REDACTED]) when
# returning client data. Resources are pulled into model context, spreading PII
# into prompts, logs, and transcripts. Set false only for internal tooling
# backed by a write-scoped key.
REDACT_PII=true

# Redirect book_from_text to the approval workflow rather than writing directly.
# Recommended in production: sampled LLM output carries implicit trust/quota
# risks and should go through booking-agent's human-approval gate.
FORCE_WORKFLOW_FOR_SAMPLING=false

# ── HTTP auth ─────────────────────────────────────────────────────────────────

# Preferred: per-client API keys with least-privilege scopes.
# Available scopes:
#   read     — read-only tools (search_availability, list_staff, etc.)
#   write    — direct DB write tools (create_booking, cancel_booking, …)
#   workflow — booking-agent workflow bridge (book_via_workflow, decide_workflow_run, …)
#   pii      — PII-tagged surfaces (get_client tool, booking://clients/ resources)
#
# Keys are stored as SHA-256 hashes only — generate records with:
#   booking-mcp-mintkey --client <name> --scopes read[,write,workflow,pii] [--expires-days N]
# Then paste the printed JSON record into the array below.
# Example (read-only key):
#   API_KEYS='[{"hash":"<sha256-hex>","client_id":"claude-desktop","scopes":["read"]}]'
# Example (full-access key):
#   API_KEYS='[{"hash":"<sha256-hex>","client_id":"ops","scopes":["read","write","workflow","pii"]}]'
API_KEYS=

# Deprecated: single shared static token granting full (read+write) access.
# Superseded by API_KEYS; kept for backward compatibility. Prefer API_KEYS for
# new deployments — it supports per-client scopes, rotation, and expiry.
AUTH_TOKEN=

# ── Workflow bridge (optional) ────────────────────────────────────────────────

# booking-agent's REST base URL. When set, the workflow-bridge tools
# (book_via_workflow / get_workflow_run / decide_workflow_run) are registered —
# they POST to booking-agent so a booking goes through its FULL human-approval
# workflow instead of writing directly. Decoupled (HTTP only). Leave empty to
# disable the bridge.
BOOKING_AGENT_URL=
BOOKING_AGENT_TIMEOUT=10.0

